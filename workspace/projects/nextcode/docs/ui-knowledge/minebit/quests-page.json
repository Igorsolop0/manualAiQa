{
  "navigation_buttons": {
    "logo": {
      "selector": "[data-testid=\"bG9nbw==\"]",
      "description": "Main logo/brand button - returns to home page"
    },
    "sidebar_toggle": {
      "selector": "[data-sidebar-button]",
      "description": "Sidebar toggle button - opens/closes navigation sidebar"
    }
  },
  "sidebar_navigation": {
    "sidebar_container": {
      "selector": "[data-testid=\"c2lkZWJhcg==\"]",
      "description": "Main sidebar container with navigation items"
    },
    "sidebar_nav": {
      "selector": "[data-testid=\"UHJpbWFyeU5hdmlnYXRpb24tc2lkZWJhci1uYXY=\"]",
      "description": "Primary navigation menu in sidebar"
    }
  },
  "main_sections": {
    "quests_header": {
      "selector": "h1:has-text('Quests'), h2:has-text('Quests')",
      "description": "Page header with 'Quests' title"
    },
    "personal_quests_section": {
      "selector": "h2:has-text('Personal Quests'), h3:has-text('Personal Quests')",
      "description": "Section for personalized quests (shows 'Join now' for new players)"
    },
    "daily_quests_section": {
      "selector": "h2:has-text('Daily Quests'), h3:has-text('Daily Quests')",
      "description": "Section containing daily quest challenges"
    },
    "weekly_quests_section": {
      "selector": "h2:has-text('Weekly Quests'), h3:has-text('Weekly Quests')",
      "description": "Section containing weekly quest challenges"
    },
    "vip_quests_section": {
      "selector": "h2:has-text('VIP Quests'), h3:has-text('VIP Quests')",
      "description": "Section for VIP-exclusive quests (shows count)"
    },
    "promo_quests_section": {
      "selector": "h2:has-text('Promo Quests'), h3:has-text('Promo Quests')",
      "description": "Section for promotional quests (shows count)"
    },
    "faq_section": {
      "selector": "h2:has-text('FAQ'), h3:has-text('FAQ'), section:has-text('Frequently Asked Questions')",
      "description": "FAQ section with questions about quests system"
    }
  },
  "navigation_tabs": {
    "available_tab": {
      "selector": "button:has-text('Available')",
      "description": "Navigation tab for available/active quests"
    },
    "completed_tab": {
      "selector": "button:has-text('Completed')",
      "description": "Navigation tab for completed quests"
    },
    "locked_tab": {
      "selector": "button:has-text('Locked')",
      "description": "Navigation tab for locked quests"
    },
    "all_tab": {
      "selector": "button:has-text('All')",
      "description": "Navigation tab to show all quests"
    }
  },
  "quest_elements": {
    "quest_card": {
      "selector": "[class*='quest-card'], [class*='QuestCard'], article:has(img):has(h2)",
      "description": "Individual quest card container with image and details"
    },
    "quest_image": {
      "selector": "[class*='quest-card'] img, [class*='QuestCard'] img",
      "description": "Quest image/icon on the card"
    },
    "quest_title": {
      "selector": "[class*='quest-card'] h2, [class*='quest-card'] h3",
      "description": "Quest title/name"
    },
    "quest_description": {
      "selector": "[class*='quest-card'] p:has-text(/exp|reward|complete/i)",
      "description": "Quest description text"
    },
    "quest_reward": {
      "selector": "text=/\\d+ exp/i, [class*='reward']",
      "description": "Quest reward information (e.g., '30 exp', '50 exp')"
    }
  },
  "progress_bars": {
    "progress_bar": {
      "selector": "[role='progressbar'], .progress-bar, [class*='ProgressBar']",
      "description": "Quest progress bar showing completion status"
    },
    "progress_text": {
      "selector": "text=/\\d+\\s*\\/\\s*\\d+/",
      "description": "Progress text (e.g., '0 / 15', '5 / 100')"
    },
    "progress_percentage": {
      "selector": "text=/\\d+%/",
      "description": "Progress percentage text"
    }
  },
  "reward_buttons": {
    "claim_button": {
      "selector": "button:has-text('Claim')",
      "description": "Button to claim quest reward (when quest is completed)"
    },
    "view_button": {
      "selector": "button:has-text('View')",
      "description": "Button to view quest details/rewards (e.g., 'View 30 exp')"
    },
    "join_button": {
      "selector": "button:has-text('Join now'), button:has-text('Join Now')",
      "description": "Button to join Personal Quests system (for new players)"
    },
    "view_all_button": {
      "selector": "button:has-text('View All')",
      "description": "Button to view all available quests"
    }
  },
  "faq_section": {
    "faq_container": {
      "selector": "section:has-text('FAQ'), div:has-text('FAQ'), [class*='faq']",
      "description": "FAQ section container"
    },
    "faq_question": {
      "selector": "button:has-text('?'), [class*='faq-question'], [class*='accordion']",
      "description": "FAQ question (clickable accordion)"
    },
    "faq_answer": {
      "selector": "[class*='faq-answer'], [class*='accordion-panel']",
      "description": "FAQ answer (expanded content)"
    }
  },
  "known_behaviors": [
    "Sticky header detected - fixed position at top",
    "Material-UI framework - dynamic rendering with lazy loading",
    "Lazy loading - 150+ images with loading='lazy' attribute",
    "Iframes detected - 4 iframes (Smartico widgets, Google Sign-in)",
    "Quest sections visibility depends on player level - new players see Personal/Daily/Weekly only",
    "Navigation tabs (Available/Completed/Locked/All) filter quest list dynamically",
    "Progress bars start at 0% for new players until actions are completed",
    "Quest cards may show different states: available, in progress, completed, locked",
    "FAQ section uses accordion pattern - questions expand/collapse on click",
    "Personal Quests section shows 'Join now' for players not enrolled in quest system"
  ]
}
