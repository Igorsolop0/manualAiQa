{
  "key": "CT-476",
  "url": "https://next-t-code.atlassian.net/browse/CT-476",
  "summary": "[FE] read and pass cashierstep, cashiersum parameters ",
  "status": "On Production",
  "priority": "Normal",
  "description": {
    "type": "doc",
    "version": 1,
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Description",
            "marks": [
              {
                "type": "strong"
              }
            ]
          },
          {
            "type": "hardBreak"
          },
          {
            "type": "text",
            "text": "We need to add support for opening the cashier at a predefined step and  prefill the amount field."
          },
          {
            "type": "hardBreak"
          },
          {
            "type": "text",
            "text": "To enable this, the frontend must read two new parameters:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "cashierstep",
                    "marks": [
                      {
                        "type": "strong"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 defines which step the cashier should open on"
                  }
                ]
              },
              {
                "type": "bulletList",
                "content": [
                  {
                    "type": "listItem",
                    "content": [
                      {
                        "type": "paragraph",
                        "content": [
                          {
                            "type": "text",
                            "text": "depositcrypto ",
                            "marks": [
                              {
                                "type": "strong"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "listItem",
                    "content": [
                      {
                        "type": "paragraph",
                        "content": [
                          {
                            "type": "text",
                            "text": "buycrypto ",
                            "marks": [
                              {
                                "type": "strong"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "listItem",
                    "content": [
                      {
                        "type": "paragraph",
                        "content": [
                          {
                            "type": "text",
                            "text": "withdrawcrypto ",
                            "marks": [
                              {
                                "type": "strong"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "cashiersum",
                    "marks": [
                      {
                        "type": "strong"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2014 prefilled amount (number)"
                  }
                ]
              },
              {
                "type": "bulletList",
                "content": [
                  {
                    "type": "listItem",
                    "content": [
                      {
                        "type": "paragraph",
                        "content": [
                          {
                            "type": "text",
                            "text": "Applies only to flows that have an amount field (e.g., "
                          },
                          {
                            "type": "text",
                            "text": "buycrypto",
                            "marks": [
                              {
                                "type": "strong"
                              }
                            ]
                          },
                          {
                            "type": "text",
                            "text": ")"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "listItem",
                    "content": [
                      {
                        "type": "paragraph",
                        "content": [
                          {
                            "type": "text",
                            "text": "Does "
                          },
                          {
                            "type": "text",
                            "text": "not",
                            "marks": [
                              {
                                "type": "strong"
                              }
                            ]
                          },
                          {
                            "type": "text",
                            "text": " apply to depositcrypto (no amount field)"
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Both parameters (cashier"
          },
          {
            "type": "text",
            "text": "step",
            "marks": [
              {
                "type": "strong"
              }
            ]
          },
          {
            "type": "text",
            "text": " and cashier"
          },
          {
            "type": "text",
            "text": "sum",
            "marks": [
              {
                "type": "strong"
              }
            ]
          },
          {
            "type": "text",
            "text": ") must be passed to the backend together with the existing cashier payload."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Optional requirement",
            "marks": [
              {
                "type": "strong"
              }
            ]
          },
          {
            "type": "hardBreak"
          },
          {
            "type": "text",
            "text": "When the cashier is closed, the frontend should clear the values of the two new parameters (cashier"
          },
          {
            "type": "text",
            "text": "step",
            "marks": [
              {
                "type": "strong"
              }
            ]
          },
          {
            "type": "text",
            "text": " and cashier"
          },
          {
            "type": "text",
            "text": "sum",
            "marks": [
              {
                "type": "strong"
              }
            ]
          },
          {
            "type": "text",
            "text": ") so they do not persist between sessions."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Expected result",
            "marks": [
              {
                "type": "strong"
              }
            ]
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Frontend reads the two new parameters from the URL"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "These parameters are included in all relevant backend requests"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Cashier opens on the correct step"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Amount field is prefilled when applicable"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "(Optional) Parameters are cleared on cashier close"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
