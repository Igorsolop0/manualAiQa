{
  "key": "CT-709",
  "url": "https://next-t-code.atlassian.net/browse/CT-709",
  "summary": "[BE] Refactor Login & Registration",
  "status": "Ready for testing",
  "priority": "Normal",
  "description": {
    "type": "doc",
    "version": 1,
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Summary:",
            "marks": [
              {
                "type": "strong"
              }
            ]
          },
          {
            "type": "hardBreak"
          },
          {
            "type": "text",
            "text": "Refactor existing login and registration logic to use external provider identifiers instead of email/user_id. Implement new table "
          },
          {
            "type": "text",
            "text": "external_registration_identifiers",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and update all social login flows."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Description:",
            "marks": [
              {
                "type": "strong"
              }
            ]
          },
          {
            "type": "hardBreak"
          },
          {
            "type": "text",
            "text": "Currently, social login (Telegram) is tied to email or to a prefixed user_id. We must introduce a new mechanism that uses external provider IDs as the primary key."
          },
          {
            "type": "hardBreak"
          },
          {
            "type": "text",
            "text": "Create a new table "
          },
          {
            "type": "text",
            "text": "external_registration_identifiers",
            "marks": [
              {
                "type": "code"
              }
            ]
          },
          {
            "type": "text",
            "text": " and update login logic to:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "On social login, read external provider ID."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Check if "
                  },
                  {
                    "type": "text",
                    "text": "(provider, external_id)",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " exists in the new table."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "If match \u2192 log in the user."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "If not \u2192 create a record; if needed, create the user (existing registration logic)."
                  },
                  {
                    "type": "hardBreak"
                  },
                  {
                    "type": "text",
                    "text": "flow logic that fills this table automatically on login (no current data exists \u2192 migration occurs via login)."
                  },
                  {
                    "type": "hardBreak"
                  },
                  {
                    "type": "text",
                    "text": "For Telegram:"
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "We currently store telegram id inside "
                  },
                  {
                    "type": "text",
                    "text": "user_id",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " with prefix."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Create migration to parse existing telegram identifiers and fill the new table."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Switch Telegram login to use "
                  },
                  {
                    "type": "text",
                    "text": "external_registration_identifiers",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": "."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Acceptance Criteria:",
            "marks": [
              {
                "type": "strong"
              }
            ]
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "New table "
                  },
                  {
                    "type": "text",
                    "text": "external_registration_identifiers",
                    "marks": [
                      {
                        "type": "code"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " created and integrated."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Telegram login flows use external_id as primary lookup."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "On first login, missing entries are created automatically."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Telegram migration successfully fills new table with correct parsed identifiers."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Old login-by-email-for-socials and login-by-prefixed-Telegram-id removed."
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "acceptance_criteria": "Found in description (ADF)",
  "recent_comments": [
    {
      "type": "doc",
      "version": 1,
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "EST: dev 1,5d test 3h"
            }
          ]
        }
      ]
    },
    {
      "type": "doc",
      "version": 1,
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Will reuse existing "
            },
            {
              "type": "text",
              "text": "ExternalIdentity",
              "marks": [
                {
                  "type": "code"
                }
              ]
            },
            {
              "type": "text",
              "text": " table"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "For each RegistrationSource will be used it\u2019s own way to determine unique identifier which will be filled in "
            },
            {
              "type": "text",
              "text": "ExternalId",
              "marks": [
                {
                  "type": "code"
                }
              ]
            },
            {
              "type": "text",
              "text": " column (In same way as Microsoft auth works for AWA)"
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "TG - "
                    },
                    {
                      "type": "text",
                      "text": "TG{userData.Id}",
                      "marks": [
                        {
                          "type": "code"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Google - "
                    },
                    {
                      "type": "text",
                      "text": "user.Email",
                      "marks": [
                        {
                          "type": "code"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "Partner-Client-ExternalIdentities uniqueness "
            },
            {
              "type": "text",
              "text": "(client can link same socials in different partners, and same socials can\u2019t be used by other users in same partner) ",
              "marks": [
                {
                  "type": "em"
                }
              ]
            },
            {
              "type": "text",
              "text": "will be checked via Client\u2019s table. "
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "Auth mechanism:"
            }
          ]
        },
        {
          "type": "orderedList",
          "attrs": {
            "order": 1
          },
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Determine unique identifier for specified RegistrationSource"
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Find records in "
                    },
                    {
                      "type": "text",
                      "text": "ExternalIdentity",
                      "marks": [
                        {
                          "type": "code"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": " table by "
                    },
                    {
                      "type": "text",
                      "text": "ExternalId == UniqueIdentifier",
                      "marks": [
                        {
                          "type": "code"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Filter by "
                    },
                    {
                      "type": "text",
                      "text": "ExternalIdentity.Client.PartnerId == PartnerId",
                      "marks": [
                        {
                          "type": "code"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "text": ", PartnerId is passed in request body"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "doc",
      "version": 1,
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
