      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "PR: "
            },
            {
              "type": "hardBreak"
            },
            {
              "type": "text",
              "text": "https://git.dolore.cc/platform/platform-be/-/merge_requests/103",
              "marks": [
                {
                  "type": "link",
                  "attrs": {
                    "href": "https://git.dolore.cc/platform/platform-be/-/merge_requests/103"
                  }
                }
