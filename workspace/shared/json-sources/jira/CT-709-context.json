                "localId": "6630bcc56113"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Google registration: new user registers via Google \u2192 verify ExternalIdentity.ExternalId = email"
                    }
                  ],
                  "attrs": {
                    "localId": "a0d3507cfc14"
                  }
                }
              ]
            },
            {
              "type": "listItem",
              "attrs": {
                "localId": "5fd345166df1"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Google email change: user changes email after linking Google \u2192 verify next Google login still works (resolves by ExternalId, not email)"
                    }
                  ],
                  "attrs": {
                    "localId": "11b535a7f703"
                  }
                }
              ]
            },
            {
              "type": "listItem",
              "attrs": {
                "localId": "6fe394205342"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Telegram login: existing TG user logs in \u2192 verify login succeeds via ExternalIdentity lookup"
                    }
                  ],
                  "attrs": {
                    "localId": "9f8c20a32084"
                  }
                }
              ]
            },
            {
              "type": "listItem",
              "attrs": {
                "localId": "0698085ac72d"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Telegram new user: register via Telegram \u2192 verify ExternalIdentity.ExternalId = TG{id}"
                    }
                  ],
                  "attrs": {
                    "localId": "35016107c462"
                  }
                }
              ]
            },
            {
              "type": "listItem",
              "attrs": {
                "localId": "d32ac7a6ed95"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Linking flow: link Google/Telegram to existing account \u2192 verify ExternalId stored correctly (not email)"
                    }
                  ],
                  "attrs": {
                    "localId": "bc9ecd9a113d"
                  }
                }
              ]
            },
            {
              "type": "listItem",
              "attrs": {
                "localId": "b3a475856d0c"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Migration verification: after deployment, spot-check DB that ExternalId is populated for existing Google and Telegram users"
                    }
                  ],
                  "attrs": {
                    "localId": "19123a76260f"
                  }
                }
              ]
            }
          ],
          "attrs": {
            "localId": "fff0bd108e88"
          }
        }
      ]
    }
