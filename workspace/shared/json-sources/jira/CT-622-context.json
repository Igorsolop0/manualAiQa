        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Main cases:"
            }
          ],
          "attrs": {
            "localId": "9a72df2d5ba5"
          }
        },
        {
          "type": "orderedList",
          "attrs": {
