          },
          "content": [
            {
              "type": "listItem",
              "attrs": {
                "localId": "3bf75f129a1f"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Site opened on desktop with MetaMask extension installed \u2014 clicking"
                    },
                    {
                      "type": "hardBreak"
                    },
                    {
                      "type": "text",
                      "text": "the auth button should open the extension"
                    }
                  ],
                  "attrs": {
                    "localId": "39c268c89139"
                  }
                }
              ]
            },
            {
              "type": "listItem",
              "attrs": {
                "localId": "9b6c4b65be59"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Site opened on desktop without the extension \u2014 a popup should appear"
                    },
                    {
                      "type": "hardBreak"
                    },
                    {
                      "type": "text",
                      "text": "with options to download the extension or scan a QR code to log in"
                    },
                    {
                      "type": "hardBreak"
                    },
                    {
                      "type": "text",
                      "text": "via mobile app"
                    }
                  ],
                  "attrs": {
                    "localId": "66b43c69fde7"
                  }
                }
              ]
            },
            {
              "type": "listItem",
              "attrs": {
                "localId": "e9d2314d21df"
              },
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Site opened on mobile \u2014 if the app is installed it should prompt"
                    },
                    {
                      "type": "hardBreak"
                    },
                    {
                      "type": "text",
                      "text": "to open it"
                    }
                  ],
                  "attrs": {
                    "localId": "0f4c83e2f527"
                  }
                }
              ]
            }
          ]
