{
  "key": "CT-473",
  "url": "https://next-t-code.atlassian.net/browse/CT-473",
  "summary": "[BO] Split the existing \u201cclient corrections\u201d role into two independent roles",
  "status": "On Production",
  "priority": "High",
  "issuetype": "Task",
  "assignee": "Kevin",
  "reporter": "Potoibicha",
  "created": "2026-03-02T11:30:02.796+0000",
  "updated": "2026-03-10T11:08:03.708+0000",
  "description": {
    "type": "doc",
    "version": 1,
    "content": [
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Problem Statement",
            "marks": [
              {
                "type": "strong"
              }
            ]
          },
          {
            "type": "hardBreak"
          },
          {
            "type": "text",
            "text": "The system currently has a single role \u201cClient corrections\u201d that allows both crediting and debiting funds. This creates operational risks, including potential fraudulent actions and human errors. A permission-separation mechanism must be implemented so that a single account cannot perform both credit and debit operations."
          }
        ]
      },
      {
        "type": "paragraph",
        "content": [
          {
            "type": "text",
            "text": "Goal",
            "marks": [
              {
                "type": "strong"
              }
            ]
          },
          {
            "type": "hardBreak"
          },
          {
            "type": "text",
            "text": "Create two independent roles:"
          }
        ]
      },
      {
        "type": "bulletList",
        "content": [
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Client credit correction",
                    "marks": [
                      {
                        "type": "strong"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2013 allowed to perform balance increase operations only."
                  }
                ]
              }
            ]
          },
          {
            "type": "listItem",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Client debit correction",
                    "marks": [
                      {
                        "type": "strong"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": " \u2013 allowed to perform balance decrease operations only."
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "attrs": {
          "level": 3
        },
