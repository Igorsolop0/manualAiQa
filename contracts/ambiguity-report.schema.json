{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ambiguity-report.schema.json",
  "title": "Ambiguity Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "project",
    "ticket_ref",
    "summary",
    "ambiguities",
    "assumptions",
    "open_questions",
    "recommended_test_levels",
    "data_env_needs",
    "decision_ready"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "project": { "type": "string", "minLength": 1 },
    "ticket_ref": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "ambiguities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "impact", "severity", "resolution_needed"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "resolution_needed": { "type": "string", "minLength": 1 }
        }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "recommended_test_levels": { "type": "array", "items": { "type": "string" } },
    "data_env_needs": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "decision_ready": { "type": "boolean" }
  }
}
